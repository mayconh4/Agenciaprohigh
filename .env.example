# NEXUS — Agency OS
# Copie este arquivo para `.env` e preencha a chave para ativar a IA REAL (Claude).
# Sem a chave, o app roda 100% em MODO DEMO (respostas locais inteligentes).

# Chave da API da Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Modelo padrão usado pela IA do produto.
# Opções: claude-sonnet-4-6 (equilíbrio, padrão) | claude-opus-4-8 (máxima qualidade) | claude-haiku-4-5-20251001 (rápido/barato)
NEXUS_MODEL=claude-sonnet-4-6

# Porta do servidor
PORT=4178
